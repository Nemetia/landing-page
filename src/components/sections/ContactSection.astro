---
import type { Translations } from "../../i18n/types"

interface Props {
  translations: Translations
}

const { translations } = Astro.props
---

<section id="contact" class="contact-section">
  <div class="contact-background-texture"></div>

  <div class="container contact-container">
    <div class="contact-heading">
      <h2 class="contact-title">
        {translations.contact.sectionTitle}
      </h2>

      <p class="contact-description">
        {translations.contact.sectionDescription}
      </p>
    </div>

    <form class="contact-form-card">
      <div class="contact-form-grid">
        <div class="contact-form-field">
          <label for="name" class="contact-form-label">
            {translations.contact.nameLabel}
          </label>

          <input
            id="name"
            name="name"
            type="text"
            class="contact-form-input"
            placeholder={translations.contact.namePlaceholder}
          />
        </div>

        <div class="contact-form-field">
          <label for="email" class="contact-form-label">
            {translations.contact.emailLabel}
          </label>

          <input
            id="email"
            name="email"
            type="email"
            class="contact-form-input"
            placeholder={translations.contact.emailPlaceholder}
          />
        </div>
      </div>

      <div class="contact-form-field">
        <label for="message" class="contact-form-label">
          {translations.contact.messageLabel}
        </label>

        <textarea
          id="message"
          name="message"
          class="contact-form-textarea"
          placeholder={translations.contact.messagePlaceholder}
          rows="4"
        ></textarea>
      </div>

      <button type="button" class="button button-primary contact-submit-button">
        {translations.contact.submitText}
      </button>
    </form>
  </div>
</section>